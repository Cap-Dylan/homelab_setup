# Jarvis Environment Configuration
# Copy to .env and fill in real values:  cp .env.example .env

# --- Home Assistant ---
HA_URL=http://<HA_LAN_IP>:8123
HA_TOKEN=your_long_lived_access_token_here

# --- Ollama (MSI) ---
OLLAMA_URL=http://<MSI_LAN_IP>:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q5_K_M

# --- Matrix (Continuwuity on MSI) ---
MATRIX_HOMESERVER=http://<MSI_TAILSCALE_IP>:6167
MATRIX_USER=@jarvis:<MSI_TAILSCALE_IP>
MATRIX_PASSWORD=your_matrix_password_here
MATRIX_ROOM_ID=!your_room_id_here:<MSI_TAILSCALE_IP>
